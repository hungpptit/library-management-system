PORT=3001
NODE_ENV=production

# Database Configuration
# Set DB_TYPE to 'postgres' for production deployment (e.g., Neon.tech, Supabase)
# Set DB_TYPE to 'mssql' for local development (MS SQL Server)
DB_TYPE=postgres
DB_HOST=your-database-host.neon.tech
DB_PORT=5432
DB_USERNAME=your-database-username
DB_PASSWORD=your-database-password
DB_DATABASE=LMS
DB_SYNCHRONIZE=true
DB_SSL=true

# CORS Configuration
# Set FRONTEND_URL to your Vercel deployment URL
FRONTEND_URL=https://your-frontend-domain.vercel.app

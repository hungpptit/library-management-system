    {
      "name": "API-002. Mượn sách vượt hạn ngạch (Negative)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "pm.test('Contains error message', function () {",
              "    var text = pm.response.text();",
              "    pm.expect(text.includes('giới hạn') || text.includes('overdue') || text.includes('Overdue')).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const sendPromise = (req) => new Promise((resolve, reject) => {",
              "    pm.sendRequest(req, (err, res) => {",
              "        if (err) reject(err);",
              "        else resolve(res);",
              "    });",
              "});",
              "",
              "(async () => {",
              "    try {",
              "        const booksRes = await sendPromise({",
              "            url: 'http://localhost:3001/api/books',",
              "            method: 'GET'",
              "        });",
              "        const books = booksRes.json();",
              "        const availableBooks = books.filter(b => b.available > 0);",
              "        if (availableBooks.length < 6) {",
              "            console.error('Not enough available books in library to perform quota test!');",
              "            return;",
              "        }",
              "        ",
              "        const uniqueId = Date.now();",
              "        const userRes = await sendPromise({",
              "            url: 'http://localhost:3001/api/users',",
              "            method: 'POST',",
              "            header: { 'Content-Type': 'application/json' },",
              "            body: {",
              "                mode: 'raw',",
              "                raw: JSON.stringify({",
              "                    email: 'quota_user_' + uniqueId + '@library.com',",
              "                    displayName: 'Quota Test Reader',",
              "                    password: '123',",
              "                    role: 'reader'",
              "                })",
              "            }",
              "        });",
              "        const userId = userRes.json().id;",
              "        ",
              "        for (let i = 0; i < 5; i++) {",
              "            await sendPromise({",
              "                url: 'http://localhost:3001/api/loans/borrow',",
              "                method: 'POST',",
              "                header: { 'Content-Type': 'application/json' },",
              "                body: {",
              "                    mode: 'raw',",
              "                    raw: JSON.stringify({",
              "                        userId: userId,",
              "                        bookId: availableBooks[i].id,",
              "                        dueDate: Date.now() + 7 * 24 * 60 * 60 * 1000",
              "                    })",
              "                }",
              "            });",
              "        }",
              "        ",
              "        pm.collectionVariables.set('quota_test_user_id', userId);",
              "        pm.collectionVariables.set('quota_test_book_id', availableBooks[5].id);",
              "    } catch (e) {",
              "        console.error('Error in quota pre-requisite: ', e);",
              "    }",
              "})();"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": {{quota_test_user_id}},\n  \"bookId\": {{quota_test_book_id}},\n  \"dueDate\": 1750000000000\n}"
        },
        "url": {
          "raw": "http://localhost:3001/api/loans/borrow",
          "protocol": "http",
          "host": [
